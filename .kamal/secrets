# Secrets referenced from config/deploy.yml (registry/password, env/secret).
# Read from local env or file — DO NOT write raw values here. This file is committed.

# GitHub PAT (write:packages scope) read from a gitignored local file.
# Create it once with:  echo "ghp_…your_token…" > .kamal/registry-password
# Path is in .gitignore, so the token never leaves your machine.
KAMAL_REGISTRY_PASSWORD=$(cat .kamal/registry-password)

# Rails credentials key — reads from gitignored config/master.key.
RAILS_MASTER_KEY=$(cat config/master.key)
