<%# locals: (event:, messages: nil, has_more: false, message: nil) -%>
<div id="<%= dom_id(event, :chat_panel) %>" class="flex-1 min-h-0 flex flex-col">
  <%= turbo_stream_from event, :chat %>

  <% if event.started? %>
    <%= render "chats/locked", event: event %>
  <% else %>
    <section class="bg-white rounded-xl shadow-sm flex flex-col flex-1 min-h-0"
             data-controller="chat-scroller">
      <div data-chat-scroller-target="viewport"
           class="chat-viewport flex-1 min-h-0 overflow-y-auto overscroll-contain px-3 pt-3 pb-2">
        <%= render "chats/sentinel", event: event, messages: messages || [], has_more: has_more %>
        <ul id="<%= dom_id(event, :chat_messages) %>"
            data-controller="chat-bubble"
            data-chat-bubble-current-user-id-value="<%= Current.user&.id %>"
            class="space-y-3 pt-1">
          <% if messages.present? && messages.any? %>
            <%= render messages %>
          <% else %>
            <li class="text-sm text-stone-400 text-center py-4" data-empty-state>
              Brak wiadomości. Zacznij rozmowę.
            </li>
          <% end %>
        </ul>
      </div>

      <div class="shrink-0 border-t border-stone-200 px-3 py-1.5">
        <%= render "chats/form", event: event, message: message || Message.new, autofocus: true %>
      </div>
    </section>
  <% end %>
</div>
