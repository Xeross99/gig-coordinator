<%= form_with model: [:host, event], local: true, class: "space-y-4" do |f| %>
  <% if event.errors.any? %>
    <div class="bg-red-50 text-red-800 rounded-lg p-3 text-sm">
      <ul class="list-disc list-inside">
        <% event.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nazwa eventu", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= label_tag "event_event_date", "Data", class: "block text-sm text-stone-700 mb-1" %>
    <%= date_field_tag "event[event_date]", event.scheduled_at&.to_date, required: true,
                       id: "event_event_date",
                       class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <label class="block text-sm text-stone-700 mb-1"><%= t("events.starts_at") %></label>
    <% preset_start_hour   = event.scheduled_at&.hour || 18 %>
    <% preset_start_minute = event.scheduled_at&.min || 0 %>
    <div class="grid grid-cols-2 gap-3">
      <div class="flex items-center gap-2">
        <%= select_tag "event[start_hour]",
                       options_for_select((0..23).map { |h| [ format("%02d", h), h ] }, preset_start_hour),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">godz.</span>
      </div>
      <div class="flex items-center gap-2">
        <%= select_tag "event[start_minute]",
                       options_for_select((0..59).step(5).map { |m| [ format("%02d", m), m ] }, preset_start_minute),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">min.</span>
      </div>
    </div>
  </div>

  <div>
    <label class="block text-sm text-stone-700 mb-1"><%= t("events.duration") %></label>
    <% total_minutes = event.scheduled_at && event.ends_at ? ((event.ends_at - event.scheduled_at) / 60).to_i : 120 %>
    <% preset_hours   = total_minutes / 60 %>
    <% preset_minutes = total_minutes % 60 %>
    <div class="grid grid-cols-2 gap-3">
      <div class="flex items-center gap-2">
        <%= number_field_tag "event[duration_hours]", preset_hours, min: 0, max: 24, required: true,
                             class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">godz.</span>
      </div>
      <div class="flex items-center gap-2">
        <%= number_field_tag "event[duration_minutes]", preset_minutes, min: 0, max: 55, step: 5, required: true,
                             class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">min.</span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :pay_per_person, t("events.pay_per_person"), class: "block text-sm text-stone-700 mb-1" %>
      <%= f.number_field :pay_per_person, step: 10, min: 0, required: true, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
    <div>
      <%= f.label :capacity, "Liczba miejsc", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.number_field :capacity, min: 1, required: true, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
  </div>

  <%= f.submit class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium" %>
<% end %>
