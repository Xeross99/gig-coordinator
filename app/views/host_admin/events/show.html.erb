<% content_for(:title) { @event.name } %>
<%= render "shared/breadcrumbs", crumbs: [[t("host_panel.my_events"), host_events_path], [@event.name, nil]], home_path: host_root_path %>

<div class="bg-white rounded-xl shadow-sm p-5">
  <h1 class="text-2xl font-semibold text-stone-900"><%= @event.name %></h1>
  <div class="mt-1 text-sm text-stone-500">
    <%= l(@event.scheduled_at, format: :long) %>
    -
    <%= l(@event.ends_at, format: :short) %>
  </div>

  <dl class="grid grid-cols-2 gap-3 mt-5">
    <div class="rounded-xl bg-emerald-50 p-3 flex items-center gap-3">
      <div class="shrink-0 size-10 rounded-lg bg-emerald-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-emerald-700" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
        </svg>
      </div>
      <div class="min-w-0">
        <dt class="text-[11px] text-emerald-800/70 font-medium uppercase tracking-wide"><%= t("events.pay_per_person") %></dt>
        <dd class="text-xl font-bold text-emerald-900 tabular-nums leading-tight mt-0.5"><%= number_to_currency(@event.pay_per_person) %></dd>
      </div>
    </div>
    <div class="rounded-xl bg-indigo-50 p-3 flex items-center gap-3">
      <div class="shrink-0 size-10 rounded-lg bg-indigo-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 text-indigo-700" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
      </div>
      <div class="min-w-0">
        <dt class="text-[11px] text-indigo-800/70 font-medium uppercase tracking-wide">Liczba miejsc</dt>
        <dd class="text-xl font-bold text-indigo-900 tabular-nums leading-tight mt-0.5"><%= @event.capacity %></dd>
      </div>
    </div>
  </dl>

  <div class="grid grid-cols-2 gap-2 mt-5">
    <%= link_to "Edytuj", edit_host_event_path(@event),
                class: "text-center py-2 rounded-lg border border-stone-300 text-sm font-medium text-stone-800 hover:bg-stone-50 transition-transform active:scale-[0.98]" %>
    <%= button_to "Usuń", host_event_path(@event), method: :delete,
                  data: { turbo_confirm: "Na pewno?" },
                  form: { class: "contents" },
                  class: "w-full py-2 rounded-lg bg-red-50 text-red-700 text-sm font-medium hover:bg-red-100 transition-transform active:scale-[0.98]" %>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm p-5 mt-4">
  <h2 class="text-lg font-semibold mb-4"><%= t("host_panel.roster") %></h2>
  <%= turbo_stream_from @event, :roster %>
  <%= render "events/roster", event: @event %>
</div>

<details class="bg-white rounded-xl shadow-sm mt-4 group">
  <summary class="cursor-pointer list-none p-5 flex items-center justify-between">
    <h2 class="text-lg font-semibold"><%= t("host_panel.history.heading") %> (<%= @history.size %>)</h2>
    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 text-stone-400 transition-transform group-open:rotate-180">
      <path fill-rule="evenodd" d="M5.22 7.22a.75.75 0 0 1 1.06 0L10 10.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 8.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
    </svg>
  </summary>
  <% if @history.any? %>
    <ul class="px-5 pb-5 space-y-2">
      <% @history.each do |e| %>
        <li class="flex items-center gap-3 text-sm text-stone-700">
          <time class="text-xs text-stone-500 tabular-nums shrink-0 w-28"><%= l(e.created_at, format: :short) %></time>
          <span class="font-medium text-stone-900 truncate"><%= e.participation.user.display_name %></span>
          <span class="text-stone-500 truncate"><%= t("host_panel.history.#{e.event_type}") %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="px-5 pb-5 text-sm text-stone-400"><%= t("host_panel.history.empty") %></p>
  <% end %>
</details>
