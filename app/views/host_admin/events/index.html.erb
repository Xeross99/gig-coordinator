<div class="flex items-center justify-between mb-5">
  <h1 class="text-2xl font-semibold"><%= t("host_panel.my_events") %></h1>
  <%= link_to t("host_panel.new_event"), new_host_event_path, class: "px-4 py-2 bg-stone-900 text-white rounded-lg text-sm font-medium" %>
</div>

<% if @events.any? %>
  <ul class="space-y-3">
    <% @events.each do |event| %>
      <li class="bg-white rounded-xl shadow-sm p-4">
        <%= link_to host_event_path(event), class: "block" do %>
          <div class="flex items-start justify-between gap-4">
            <div>
              <div class="font-medium text-stone-900"><%= event.name %></div>
              <div class="text-sm text-stone-500 mt-0.5"><%= l(event.scheduled_at, format: :long) %></div>
            </div>
            <div class="text-right text-xs">
              <div class="text-stone-500"><%= event.capacity %> <%= t("events.seats") %></div>
              <div class="text-stone-900 font-medium mt-1"><%= number_to_currency(event.pay_per_person) %></div>
            </div>
          </div>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="text-stone-500 py-8 text-center">Brak eventów.</div>
<% end %>
