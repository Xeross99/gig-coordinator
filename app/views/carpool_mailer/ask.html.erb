<%= render "mailers/title", text: "Prośba o podwózkę" %>
<%= render "mailers/paragraph", html: t("mailers.hello", name: @driver.first_name) %>
<%= render "mailers/paragraph",
           html: safe_join([
             tag.strong(@passenger.display_name),
             " pyta, czy może jechać z Tobą na event ",
             tag.strong(@event.name),
             ".",
             tag.br, tag.br,
             "Start: ",
             tag.strong(l(@event.scheduled_at, format: :long))
           ]) %>
<%= render "mailers/cta_button", label: "Odpowiedz w aplikacji", url: event_url(@event) %>
<%= render "mailers/raw_url", url: event_url(@event) %>
