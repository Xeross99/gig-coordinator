<%= render "mailers/title", text: "Cześć #{@record.first_name}!" %>

<%= render "mailers/paragraph", html: safe_join([
  "Kliknij przycisk poniżej, żeby zalogować się do aplikacji.".html_safe,
  tag.br,
  "Link wygaśnie za ".html_safe,
  tag.strong("15 minut", style: "color:#0c0a09"),
  "."
]) %>

<%= render "mailers/cta_button", label: "Zaloguj się", url: @url %>
<%= render "mailers/raw_url", url: @url %>
