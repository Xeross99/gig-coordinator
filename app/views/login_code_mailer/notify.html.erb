<%= render "mailers/title", text: "Cześć #{@record.first_name}!" %>

<%= render "mailers/paragraph", html: safe_join([
  "Oto Twój 5-cyfrowy kod logowania. Wpisz go w aplikacji, aby się zalogować.".html_safe,
  tag.br,
  "Kod wygaśnie za ".html_safe,
  tag.strong("15 minut", style: "color:#0c0a09"),
  "."
]) %>

<table width="100%" border="0" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding:16px 20px 24px;text-align:center">
      <span style="display:inline-block;padding:16px 28px;background:#f5f5f4;border-radius:12px;font-size:36px;font-family:'Courier New',Courier,monospace;font-weight:bold;letter-spacing:10px;color:#0c0a09">
        <%= @code %>
      </span>
    </td>
  </tr>
</table>

<%= render "mailers/paragraph", html: "Jeśli to nie Ty prosiłeś o logowanie, po prostu zignoruj tego maila." %>
