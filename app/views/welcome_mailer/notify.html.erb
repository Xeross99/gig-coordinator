<%= render "mailers/title", text: "Witaj w Gig Coordinator, #{@record.first_name}!" %>

<% if @is_host %>
  <%= render "mailers/paragraph", html: safe_join([
    "Twoje konto ".html_safe,
    tag.strong("organizatora"),
    " jest gotowe. Od teraz możesz planować łapania w panelu organizatora i zapraszać pracowników."
  ]) %>

  <%= render "mailers/paragraph", html: "Zaloguj się adresem e-mail, na który przyszedł ten mail — wyślemy Ci 5-cyfrowy kod logowania." %>
<% else %>
  <%= render "mailers/paragraph", html: safe_join([
    "Twoje konto ".html_safe,
    tag.strong("pracownika"),
    " jest gotowe. Od teraz będziesz dostawać powiadomienia o nowych łapaniach kur u organizatorów."
  ]) %>

  <%= render "mailers/paragraph", html: "Zaloguj się tym samym adresem e-mail — wyślemy Ci 5-cyfrowy kod." %>
<% end %>

<%= render "mailers/paragraph", html: safe_join([
  "Nie wiesz jak zacząć? ".html_safe,
  tag.a("Zobacz poradnik krok po kroku", href: @guide_url, style: "color:#0c0a09;text-decoration:underline"),
  " — jak dodać aplikację do ekranu głównego i włączyć powiadomienia."
]) %>

<%= render "mailers/cta_button", label: "Otwórz aplikację", url: @url %>
<%= render "mailers/raw_url", url: @url %>

<%= render "mailers/paragraph", html: "Miłego łapania! 🐔" %>
