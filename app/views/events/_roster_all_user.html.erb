<%# locals: (event:, user:, index:, participation:, blocked:, driver_offer:, own_request:, current_user_is_participant:, current_user_drives:) -%>
<% is_me = Current.user && Current.user.id == user.id %>
<% is_driver = driver_offer.present? %>
<% user_is_participant = participation && participation.status != "cancelled" %>
<li class="flex flex-col gap-2 rounded-lg px-3 py-2 text-sm bg-stone-50 animate-pop-in"
    style="animation-delay: <%= index * 40 %>ms">
  <div class="flex items-center gap-3">
    <%= render "events/roster_avatar", user: user %>
    <div class="min-w-0 flex-1">
      <div class="font-medium text-stone-900 truncate">
        <%= user.display_name %>
        <% if is_driver %>
          <span class="inline-flex items-center gap-1 align-middle ml-1 text-xs text-sky-700 bg-sky-100 rounded-full px-2 py-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-3.5">
              <path d="M3.375 8.25A3.375 3.375 0 0 1 6.72 5.25h10.56a3.375 3.375 0 0 1 3.345 3l.226 2.05a.75.75 0 0 0 .176.392l.777.856A2.25 2.25 0 0 1 22.5 13.058V16.5A1.5 1.5 0 0 1 21 18h-.75v.75a1.5 1.5 0 0 1-3 0V18h-10.5v.75a1.5 1.5 0 0 1-3 0V18H3a1.5 1.5 0 0 1-1.5-1.5v-3.442a2.25 2.25 0 0 1 .696-1.51l.777-.856a.75.75 0 0 0 .176-.392l.226-2.05Zm3.345-1.5a1.875 1.875 0 0 0-1.861 1.667l-.184 1.666h14.65l-.184-1.666A1.875 1.875 0 0 0 17.28 6.75H6.72ZM6 14.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm12 0a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" />
            </svg>
            Kierowca
          </span>
        <% end %>
      </div>
      <div class="mt-0.5"><%= render "users/title_badge", user: user %></div>
    </div>
    <% if blocked %>
      <span class="inline-flex items-center gap-1 text-xs text-red-600 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true" class="size-3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
        </svg>
        blokada
      </span>
    <% else %>
      <% case participation&.status %>
      <% when "reserved" %>
        <span class="text-xs text-indigo-600 shrink-0">oczekuje</span>
      <% when "confirmed" %>
        <span class="text-xs text-emerald-600 shrink-0">zapisany</span>
      <% when "waitlist" %>
        <span class="text-xs text-amber-600 shrink-0">rezerwa</span>
      <% when "cancelled" %>
        <span class="text-xs text-stone-400 shrink-0">anulował</span>
      <% end %>
    <% end %>
  </div>

  <% if is_me && current_user_is_participant %>
    <%# Przycisk „zgłoś się jako kierowca" / „zrezygnuj" przy swoim własnym wierszu.
        Przycisk „zgłoś się" pokazujemy tylko gdy user ma uprawnienia kierowcy
        (flaga `can_drive` ustawiana przez admina). „Zrezygnuj" zostaje
        zawsze — jeśli uprawnienia zostaną odebrane po zgłoszeniu, user nadal
        musi móc zdjąć z siebie funkcję. %>
    <% if is_driver %>
      <%= button_to event_carpool_offer_path(event), method: :delete,
                    data: { turbo_confirm: "Na pewno zrezygnujesz z funkcji kierowcy? Wszystkie zapytania pasażerów zostaną usunięte." },
                    class: "w-full text-xs font-medium py-1.5 rounded-md border border-stone-300 text-stone-700 bg-white hover:bg-stone-100 transition-colors" do %>
        Zrezygnuj z funkcji kierowcy
      <% end %>
    <% elsif Current.user.can_drive? && participation&.confirmed? %>
      <%= button_to event_carpool_offer_path(event), method: :post,
                    class: "w-full text-xs font-medium py-1.5 rounded-md bg-sky-600 text-white hover:bg-sky-700 transition-colors" do %>
        Zgłoś się jako kierowca
      <% end %>
    <% end %>
  <% elsif !is_me && is_driver && current_user_is_participant && !current_user_drives %>
    <%# Ktoś inny jest kierowcą — ja mogę zapytać. %>
    <% case own_request&.status %>
    <% when "pending" %>
      <div class="flex items-center justify-between gap-2">
        <span class="text-xs text-amber-700">Czekasz na potwierdzenie kierowcy…</span>
        <%= button_to "Wycofaj", event_carpool_request_path(event, own_request), method: :delete,
                      class: "text-xs font-medium py-1 px-2 rounded-md border border-stone-300 text-stone-700 bg-white hover:bg-stone-100" %>
      </div>
    <% when "accepted" %>
      <div class="text-xs text-emerald-700">Kierowca potwierdził, jedziesz z nim.</div>
    <% when "declined" %>
      <div class="flex items-center justify-between gap-2">
        <span class="text-xs text-red-700">Kierowca odrzucił prośbę.</span>
        <% if driver_offer.seats_left > 0 %>
          <%= button_to "Zapytaj ponownie", event_carpool_requests_path(event, carpool_offer_id: driver_offer.id), method: :post,
                        class: "text-xs font-medium py-1 px-2 rounded-md bg-sky-600 text-white hover:bg-sky-700" %>
        <% end %>
      </div>
    <% else %>
      <% if driver_offer.seats_left > 0 %>
        <%= button_to event_carpool_requests_path(event, carpool_offer_id: driver_offer.id), method: :post,
                      class: "w-full text-xs font-medium py-1.5 rounded-md bg-sky-600 text-white hover:bg-sky-700 transition-colors" do %>
          Zapytaj o podwózkę (<%= driver_offer.seats_left %>/<%= CarpoolOffer::SEATS %> wolne)
        <% end %>
      <% else %>
        <span class="text-xs text-stone-500">Auto zajęte (<%= driver_offer.seats_taken %>/<%= CarpoolOffer::SEATS %>)</span>
      <% end %>
    <% end %>
  <% end %>
</li>
