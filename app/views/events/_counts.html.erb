<div id="<%= dom_id(event, :counts) %>" class="flex items-center justify-between mb-3 flex-wrap gap-2">
  <div class="text-sm">
    <span class="text-stone-500"><%= t("events.confirmed_count") %>:</span>
    <span class="font-semibold inline-block animate-bump tabular-nums"><%= event.slots_taken %>/<%= event.capacity %></span>
    <% if event.reserved_count.positive? %>
      <span class="text-xs text-indigo-600">(<%= event.reserved_count %> oczekuje)</span>
    <% end %>
  </div>
  <div class="text-sm">
    <span class="text-stone-500"><%= t("events.waitlist_count") %>:</span>
    <span class="font-semibold inline-block animate-bump tabular-nums"><%= event.waitlist_count %></span>
  </div>
</div>
