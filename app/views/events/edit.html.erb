<% content_for(:title) { t("events.edit_event") } %>
<%= render "shared/breadcrumbs", crumbs: [
  [ t("events.upcoming"), root_path ],
  [ @event.name, event_path(@event) ],
  [ t("events.edit_event"), nil ]
] %>

<h1 class="text-2xl font-semibold mb-4"><%= t("events.edit_event") %></h1>

<%= render "form",
           event: @event,
           hosts: @hosts,
           url: event_path(@event),
           submit_label: t("events.save_changes") %>
