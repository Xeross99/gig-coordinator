<% if user.photo.attached? %>
  <%= image_tag rails_representation_path(user.photo.variant(:roster), only_path: true),
                alt: user.display_name,
                class: "size-10 rounded-full object-cover shrink-0" %>
<% else %>
  <div class="size-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 text-xs font-semibold shrink-0"
       aria-hidden="true">
    <%= user.first_name[0] %><%= user.last_name[0] %>
  </div>
<% end %>
