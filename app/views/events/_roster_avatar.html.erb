<% if user.photo.attached? %>
  <%= image_tag user.photo.variant(resize_to_fill: [ 32, 32 ]),
                alt: user.display_name,
                class: "size-8 rounded-full object-cover shrink-0" %>
<% else %>
  <div class="size-8 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 text-xs font-semibold shrink-0"
       aria-hidden="true">
    <%= user.first_name[0] %><%= user.last_name[0] %>
  </div>
<% end %>
