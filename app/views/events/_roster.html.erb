<div id="<%= dom_id(event, :roster) %>" class="space-y-4">
  <% reserved = event.participations.reserved.includes(user: { photo_attachment: :blob }).order(:position) %>
  <% if reserved.any? %>
    <div>
      <h3 class="text-stone-500 text-xs uppercase tracking-wide mb-2">
        Rezerwacje (<%= reserved.size %>)
      </h3>
      <ul class="space-y-2">
        <% reserved.each_with_index do |p, i| %>
          <li class="flex items-center gap-3 bg-indigo-50 rounded-lg px-3 py-2 text-sm animate-pop-in"
              style="animation-delay: <%= i * 40 %>ms">
            <%= render "events/roster_avatar", user: p.user %>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-4 text-indigo-500 animate-spin shrink-0">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="14 40"/>
            </svg>
            <div class="min-w-0 flex-1">
              <div class="font-medium text-stone-900 truncate"><%= p.user.display_name %></div>
              <div class="mt-0.5"><%= render "users/title_badge", user: p.user %></div>
            </div>
            <span class="text-xs text-indigo-600 shrink-0">oczekuje</span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <h3 class="text-stone-500 text-xs uppercase tracking-wide mb-2">
      <%= t("events.confirmed_count") %>
      (<%= event.participations.confirmed.count %>/<%= event.capacity %>)
    </h3>
    <% confirmed = event.participations.confirmed.includes(user: { photo_attachment: :blob }).order(:position) %>
    <% if confirmed.any? %>
      <ul class="space-y-2">
        <% confirmed.each_with_index do |p, i| %>
          <li class="flex items-center gap-3 bg-emerald-50 rounded-lg px-3 py-2 text-sm animate-pop-in"
              style="animation-delay: <%= i * 40 %>ms">
            <%= render "events/roster_avatar", user: p.user %>
            <div class="min-w-0 flex-1">
              <div class="font-medium text-stone-900 truncate"><%= p.user.display_name %></div>
              <div class="mt-0.5"><%= render "users/title_badge", user: p.user %></div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="text-stone-400 text-sm">Brak zapisanych.</div>
    <% end %>
  </div>

  <div>
    <h3 class="text-stone-500 text-xs uppercase tracking-wide mb-2">
      <%= t("events.waitlist_count") %>
      (<%= event.participations.waitlist.count %>)
    </h3>
    <% waitlist = event.participations.waitlist.includes(user: { photo_attachment: :blob }).order(:position) %>
    <% if waitlist.any? %>
      <ul class="space-y-2">
        <% waitlist.each_with_index do |p, i| %>
          <li class="flex items-center gap-3 bg-amber-50 rounded-lg px-3 py-2 text-sm animate-pop-in"
              style="animation-delay: <%= i * 40 %>ms">
            <%= render "events/roster_avatar", user: p.user %>
            <div class="min-w-0 flex-1">
              <div class="font-medium text-stone-900 truncate"><%= p.user.display_name %></div>
              <div class="mt-0.5"><%= render "users/title_badge", user: p.user %></div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="text-stone-400 text-sm">Lista rezerwowa pusta.</div>
    <% end %>
  </div>

  <% all_users = User.with_attached_photo.order(title: :desc, last_name: :asc, first_name: :asc) %>
  <% participations_by_user = event.participations.index_by(&:user_id) %>
  <% blocked_user_ids = HostBlock.where(host_id: event.host_id).pluck(:user_id).to_set %>
  <% initial_cap = 4 %>
  <% visible_users, hidden_users = all_users.first(initial_cap), all_users.drop(initial_cap) %>
  <div class="pt-4 border-t border-stone-200">
    <h3 class="text-stone-500 text-xs uppercase tracking-wide mb-2">
      Wszyscy pracownicy (<%= all_users.size %>)
    </h3>
    <ul class="space-y-2">
      <% visible_users.each_with_index do |user, i| %>
        <%= render "events/roster_all_user",
                    user:          user,
                    index:         i,
                    participation: participations_by_user[user.id],
                    blocked:       blocked_user_ids.include?(user.id) %>
      <% end %>
    </ul>

    <% if hidden_users.any? %>
      <div data-controller="roster-expand"
           data-roster-expand-count-value="<%= hidden_users.size %>">
        <div data-roster-expand-target="collapsible" class="roster-collapsible">
          <div class="min-h-0">
            <ul class="space-y-2 pt-2">
              <% hidden_users.each_with_index do |user, i| %>
                <%= render "events/roster_all_user",
                            user:          user,
                            index:         i,
                            participation: participations_by_user[user.id],
                            blocked:       blocked_user_ids.include?(user.id) %>
              <% end %>
            </ul>
          </div>
        </div>
        <button type="button"
                data-roster-expand-target="button"
                data-action="click->roster-expand#toggle"
                class="mt-2 w-full text-center text-xs font-medium py-2 rounded-lg text-indigo-600 hover:text-indigo-700 hover:bg-indigo-50 transition-colors">
          Pokaż wszystkich (<%= hidden_users.size %>)
        </button>
      </div>
    <% end %>
  </div>
</div>
