<div class="mb-4">
  <h1 class="text-2xl font-semibold"><%= t("events.upcoming") %></h1>
</div>

<% if @hosts.any? %>
  <%= form_with url: root_path, method: :get, local: true, class: "mb-4" do %>
    <select name="host_id" onchange="this.form.requestSubmit()"
            class="w-full px-3 py-3 rounded-lg border border-stone-300 bg-white">
      <option value="">Wszyscy organizatorzy</option>
      <% @hosts.each do |h| %>
        <option value="<%= h.id %>" <%= "selected" if @selected_host_id == h.id %>><%= h.display_name %></option>
      <% end %>
    </select>
  <% end %>
<% end %>

<%= turbo_stream_from :events %>

<ul id="events_list" class="space-y-3">
  <% @events.each do |event| %>
    <%= render "event_card", event: event %>
  <% end %>
</ul>

<div id="events_empty" class="<%= "hidden" unless @events.empty? %> text-stone-500 py-8 text-center">
  Brak nadchodzących eventów.
</div>
