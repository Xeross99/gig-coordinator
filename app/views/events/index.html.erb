<% content_for(:title) { t("events.upcoming") } %>
<div class="mb-4">
  <h1 class="text-2xl font-semibold"><%= t("events.upcoming") %></h1>
</div>

<% if @hosts.any? %>
  <%= form_with url: root_path, method: :get, local: true, class: "mb-4" do %>
    <label for="host_id" class="sr-only">Filtruj po organizatoru</label>
    <div class="mt-2 grid grid-cols-1">
      <select id="host_id" name="host_id" onchange="this.form.requestSubmit()"
              class="col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-2 pr-8 pl-3 text-base text-stone-900 outline-1 -outline-offset-1 outline-stone-300 focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-stone-900 sm:text-sm/6">
        <option value="">Wszyscy organizatorzy</option>
        <% @hosts.each do |h| %>
          <option value="<%= h.id %>" <%= "selected" if @selected_host_id == h.id %>><%= h.display_name %></option>
        <% end %>
      </select>
      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"
           class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end text-stone-500 sm:size-4">
        <path d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
      </svg>
    </div>
  <% end %>
<% end %>

<%= turbo_stream_from :events %>
<%= turbo_stream_from current_user, :events %>

<% pending_event_ids = Set.new(current_user.participations.reserved.where("reserved_until > ?", Time.current).pluck(:event_id)) %>

<ul id="events_list" class="space-y-3">
  <% @events.each do |event| %>
    <%= render "event_card", event: event, pending_reservation: pending_event_ids.include?(event.id) %>
  <% end %>
</ul>

<div id="events_empty" class="<%= "hidden" unless @events.empty? %> text-stone-500 py-8 text-center">
  Brak nadchodzących eventów.
</div>
