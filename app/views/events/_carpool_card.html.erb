<%# locals: (event:, offer:) -%>
<% is_driver_me = Current.user && Current.user.id == offer.user_id %>
<% accepted = offer.carpool_requests.select(&:accepted?) %>
<% pending  = offer.carpool_requests.select(&:pending?) %>
<% seats_left = offer.seats_left %>
<li class="rounded-lg bg-sky-50 px-3 py-3 text-sm animate-pop-in">
  <div class="flex items-center gap-3">
    <%= render "events/roster_avatar", user: offer.user %>
    <div class="min-w-0 flex-1">
      <div class="font-medium text-stone-900 truncate"><%= offer.user.display_name %></div>
      <div class="text-xs text-sky-800 mt-0.5">
        Kierowca · wolne miejsca: <%= seats_left %>/<%= CarpoolOffer::SEATS %>
      </div>
    </div>
  </div>

  <% if accepted.any? %>
    <div class="mt-2 text-xs text-stone-600 uppercase tracking-wide">Pasażerowie</div>
    <ul class="mt-1 space-y-1">
      <% accepted.each do |req| %>
        <li class="flex items-center justify-between gap-2 bg-white/60 rounded px-2 py-1">
          <div class="flex items-center gap-2 min-w-0">
            <%= render "events/roster_avatar", user: req.user %>
            <span class="text-stone-800 truncate"><%= req.user.display_name %></span>
          </div>
          <% if !event.started? %>
            <% if is_driver_me %>
              <%= button_to "Usuń", decline_event_carpool_request_path(event, req), method: :post,
                            data: { turbo_confirm: "Usunąć pasażera z auta?" },
                            class: "text-xs font-medium py-0.5 px-2 rounded border border-stone-300 text-stone-700 bg-white hover:bg-stone-100" %>
            <% elsif Current.user && req.user_id == Current.user.id %>
              <%= button_to event_carpool_request_path(event, req), method: :delete,
                            data: { turbo_confirm: "Zrezygnujesz z podwózki?" },
                            class: "text-xs font-medium py-0.5 px-2 rounded border border-stone-300 text-stone-700 bg-white hover:bg-stone-100",
                            title: "Zrezygnuj z podwózki",
                            "aria-label": "Zrezygnuj z podwózki" do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true" class="size-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
                </svg>
              <% end %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if is_driver_me && pending.any? && !event.started? %>
    <div class="mt-3 text-xs text-stone-600 uppercase tracking-wide">Zapytania (<%= pending.size %>)</div>
    <ul class="mt-1 space-y-1">
      <% pending.each do |req| %>
        <li class="flex items-center justify-between gap-2 bg-white rounded px-2 py-1.5">
          <div class="flex items-center gap-2 min-w-0">
            <%= render "events/roster_avatar", user: req.user %>
            <span class="text-stone-800 truncate"><%= req.user.display_name %></span>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <%= button_to "Potwierdź", accept_event_carpool_request_path(event, req), method: :post,
                          class: "text-xs font-medium py-1 px-2 rounded bg-emerald-600 text-white hover:bg-emerald-700 #{'opacity-50 cursor-not-allowed' if seats_left < 1}",
                          disabled: seats_left < 1 %>
            <%= button_to "Odrzuć", decline_event_carpool_request_path(event, req), method: :post,
                          class: "text-xs font-medium py-1 px-2 rounded border border-stone-300 text-stone-700 bg-white hover:bg-stone-100" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% elsif !is_driver_me && pending.any? %>
    <div class="mt-2 text-xs text-stone-500">
      <%= pending.size %> <%= pending.size == 1 ? "osoba czeka" : "osób czeka" %> na odpowiedź kierowcy.
    </div>
  <% end %>
</li>
