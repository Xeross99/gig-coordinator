<% content_for(:title) { @event.name } %>
<%= render "shared/breadcrumbs", crumbs: [[@event.name, nil]] %>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0 flex-1">
        <h1 class="text-2xl font-semibold text-stone-900"><%= @event.name %></h1>
        <div class="mt-1 text-sm text-stone-500 space-y-1">
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
            </svg>
            <%= l(@event.scheduled_at, format: :long) %>
          </div>
          <div class="flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Przewidywany czas: <%= event_duration_text(@event) %>
          </div>
        </div>
      </div>
      <% chat_count    = @event.messages_count %>
      <% history_count = @event.history_count %>
      <% capped_count  = ->(n) { n > 99 ? "99+" : n.to_s } %>
      <div class="shrink-0 flex flex-col items-end gap-2">
        <%= link_to event_chat_path(@event),
                    title: "Czat eventu",
                    aria: { label: "Czat eventu" },
                    class: "relative inline-flex items-center justify-center size-11 rounded-xl bg-stone-900 text-white hover:bg-stone-800" do %>
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
            <path fill-rule="evenodd" d="M10 2c-4.418 0-8 3.134-8 7 0 1.892.856 3.611 2.249 4.872A6.49 6.49 0 0 1 2.5 16.5a.75.75 0 0 0 .574 1.213 7.5 7.5 0 0 0 4.075-1.341A9.22 9.22 0 0 0 10 16c4.418 0 8-3.134 8-7s-3.582-7-8-7Z" clip-rule="evenodd" />
          </svg>
          <% if chat_count.positive? %>
            <span class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-red-500 text-white text-[10px] font-semibold tabular-nums flex items-center justify-center ring-2 ring-white"><%= capped_count.call(chat_count) %></span>
          <% end %>
        <% end %>
        <%= link_to history_event_path(@event),
                    title: "Historia wydarzeń",
                    aria: { label: "Historia wydarzeń" },
                    class: "relative inline-flex items-center justify-center size-11 rounded-xl bg-stone-100 text-stone-700 hover:bg-stone-200" do %>
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .199.079.39.22.53l3 3a.75.75 0 1 0 1.06-1.06l-2.78-2.78V5Z" clip-rule="evenodd" />
          </svg>
          <% if history_count.positive? %>
            <span class="absolute -top-1 -right-1 min-w-5 h-5 px-1 rounded-full bg-stone-700 text-white text-[10px] font-semibold tabular-nums flex items-center justify-center ring-2 ring-white"><%= capped_count.call(history_count) %></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Kluczowe liczby (stawka + miejsca) — karty z kolorowym tłem żeby dało
        się jednym rzutem oka wyłuskać „ile zapłacą" i „ile jest miejsc". -%>
    <dl class="grid grid-cols-2 gap-3 mt-5">
      <div class="rounded-xl bg-emerald-50 p-3">
        <div class="flex items-start justify-between gap-2">
          <dt class="text-[11px] text-emerald-800/70 font-medium uppercase tracking-wide leading-tight"><%= t("events.pay_per_person") %></dt>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 shrink-0 text-emerald-600" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" />
          </svg>
        </div>
        <dd class="text-2xl font-bold text-emerald-900 tabular-nums leading-tight mt-2"><%= number_to_currency(@event.pay_per_person) %></dd>
      </div>
      <div class="rounded-xl bg-indigo-50 p-3">
        <div class="flex items-start justify-between gap-2">
          <dt class="text-[11px] text-indigo-800/70 font-medium uppercase tracking-wide leading-tight">Liczba miejsc</dt>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 shrink-0 text-indigo-600" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
          </svg>
        </div>
        <dd class="text-2xl font-bold text-indigo-900 tabular-nums leading-tight mt-2"><%= @event.capacity %></dd>
      </div>
    </dl>
  </div>

  <div class="border-t border-stone-200 p-5">
    <div class="text-stone-500 text-xs uppercase tracking-wide mb-2"><%= t("events.host") %></div>
    <div class="flex items-center gap-3">
      <% if @host.photo.attached? %>
        <%= image_tag @host.photo.variant(:small), alt: @host.display_name, class: "size-12 rounded-full object-cover" %>
      <% else %>
        <div class="size-12 rounded-full bg-stone-200 flex items-center justify-center text-stone-500 font-semibold text-sm">
          <%= @host.first_name[0] %><%= @host.last_name[0] %>
        </div>
      <% end %>
      <div>
        <div class="font-medium"><%= @host.display_name %></div>
        <div class="text-sm text-stone-500"><%= @host.location %></div>
      </div>
    </div>

    <div class="mt-4 rounded-lg overflow-hidden border border-stone-200">
      <%= render "shared/map_embed", location: @host.location, height_class: "h-60" %>
    </div>
    <%= link_to t("events.open_in_maps"), google_maps_open_url(@host.location),
                target: "_blank", rel: "noopener",
                class: "block text-center mt-3 text-sm text-stone-600 hover:text-stone-900" %>
  </div>

  <div class="border-t border-stone-200 p-5">
    <%= turbo_frame_tag dom_id(@event, :participation) do %>
      <%= render "events/participation_button", event: @event %>
    <% end %>
  </div>

  <% if admin_signed_in? %>
    <div class="border-t border-stone-200 p-5">
      <div class="text-stone-500 text-xs uppercase tracking-wide mb-2"><%= t("admin.events.tools") %></div>
      <div class="grid grid-cols-2 gap-2">
        <%= link_to t("admin.events.edit"), edit_event_path(@event),
                    class: "text-center py-2 rounded-lg border border-stone-300 text-sm font-medium text-stone-800 hover:bg-stone-50 transition-transform active:scale-[0.98]" %>
        <%= button_to t("admin.events.delete"), event_path(@event), method: :delete,
                      data: { turbo_confirm: t("admin.events.delete_confirm", name: @event.name) },
                      form: { class: "contents" },
                      class: "w-full py-2 rounded-lg bg-red-50 text-red-700 text-sm font-medium hover:bg-red-100 transition-transform active:scale-[0.98]" %>
      </div>
    </div>
  <% end %>

  <div class="border-t border-stone-200 p-5">
    <%= turbo_stream_from @event, :roster %>
    <%= render "events/roster", event: @event %>
  </div>
</div>

