<% content_for(:title) { @event.name } %>
<%= render "shared/breadcrumbs", crumbs: [[t("events.upcoming"), root_path], [@event.name, nil]] %>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <h1 class="text-2xl font-semibold text-stone-900 min-w-0"><%= @event.name %></h1>
      <%= link_to history_event_path(@event),
                  title: "Historia łapania",
                  class: "shrink-0 inline-flex items-center gap-1.5 rounded-full bg-stone-100 text-stone-700 hover:bg-stone-200 px-3 py-1 text-xs font-medium mt-1.5" do %>
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-3.5">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .199.079.39.22.53l3 3a.75.75 0 1 0 1.06-1.06l-2.78-2.78V5Z" clip-rule="evenodd" />
        </svg>
        Historia
      <% end %>
    </div>
    <div class="mt-1 text-sm text-stone-500 space-y-1">
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
        </svg>
        <%= l(@event.scheduled_at, format: :long) %>
      </div>
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        Przewidywany czas: <%= event_duration_text(@event) %>
      </div>
    </div>

    <dl class="grid grid-cols-2 gap-3 mt-4 text-sm">
      <div>
        <dt class="text-stone-500"><%= t("events.pay_per_person") %></dt>
        <dd class="font-medium"><%= number_to_currency(@event.pay_per_person) %></dd>
      </div>
      <div>
        <dt class="text-stone-500">Liczba miejsc</dt>
        <dd class="font-medium"><%= @event.capacity %></dd>
      </div>
    </dl>
  </div>

  <div class="border-t border-stone-200 p-5">
    <div class="text-stone-500 text-xs uppercase tracking-wide mb-2"><%= t("events.host") %></div>
    <div class="flex items-center gap-3">
      <% if @host.photo.attached? %>
        <%= image_tag @host.photo.variant(:small), class: "w-12 h-12 rounded-full object-cover" %>
      <% else %>
        <div class="w-12 h-12 rounded-full bg-stone-200 flex items-center justify-center text-stone-500 font-semibold text-sm">
          <%= @host.first_name[0] %><%= @host.last_name[0] %>
        </div>
      <% end %>
      <div>
        <div class="font-medium"><%= @host.display_name %></div>
        <div class="text-sm text-stone-500"><%= @host.location %></div>
      </div>
    </div>

    <div class="mt-4 rounded-lg overflow-hidden border border-stone-200">
      <%= render "shared/map_embed", location: @host.location, height_class: "h-60" %>
    </div>
    <%= link_to t("events.open_in_maps"), google_maps_open_url(@host.location),
                target: "_blank", rel: "noopener",
                class: "block text-center mt-3 text-sm text-stone-600 hover:text-stone-900" %>
  </div>

  <div class="border-t border-stone-200 p-5">
    <%= turbo_frame_tag dom_id(@event, :participation) do %>
      <%= render "events/participation_button", event: @event %>
    <% end %>
  </div>

  <div class="border-t border-stone-200 p-5">
    <%= turbo_stream_from @event, :roster %>
    <%= render "events/roster", event: @event %>
  </div>
</div>

<%# Czat dojeżdża lazy w osobnej ramce — pierwsze malowanie strony (roster +
    przycisk zapisu) nie czeka na żadne zapytanie związane z wiadomościami. %>
<div class="mt-4">
  <%= turbo_frame_tag "event_chat", src: event_chat_path(@event), loading: "lazy" do %>
    <div class="bg-white rounded-xl shadow-sm p-4 text-stone-400 text-sm text-center">
      Wczytuję czat…
    </div>
  <% end %>
</div>
