<% participation = event.participations.active.find_by(user_id: current_user&.id) %>

<%= turbo_stream_from event, :counts %>
<%= render "events/counts", event: event %>

<% if participation&.reserved? && !participation.reservation_expired? %>
  <% remaining_min = ((participation.reserved_until - Time.current) / 60).to_i %>
  <div class="rounded-lg bg-indigo-50 text-indigo-900 px-3 py-2 text-sm mb-3 animate-pop-in">
    <div class="flex items-center gap-2">
      <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" class="size-4 text-indigo-500 animate-spin shrink-0">
        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-dasharray="14 40"/>
      </svg>
      <span class="font-semibold">Masz rezerwację</span>
    </div>
    <div class="text-xs mt-1 text-indigo-700">
      Deadline: <%= l(participation.reserved_until, format: :short) %> (zostało ok. <%= [ remaining_min, 0 ].max %> min)
    </div>
  </div>
  <div class="grid grid-cols-2 gap-2">
    <%= button_to "Akceptuję", accept_event_participation_path(event), method: :post,
                  form: { class: "contents", data: { turbo_frame: "_top" } },
                  class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium transition-transform active:scale-[0.97] hover:bg-stone-800" %>
    <%= button_to "Odrzuć", decline_event_participation_path(event), method: :post,
                  form: { class: "contents", data: { turbo_frame: "_top" } },
                  class: "w-full py-3 rounded-lg border border-stone-300 text-stone-800 font-medium transition-transform active:scale-[0.97]" %>
  </div>
<% elsif participation&.confirmed? %>
  <div class="rounded-lg bg-emerald-50 text-emerald-800 px-3 py-2 text-sm mb-3 animate-pop-in"><%= t("events.confirmed_badge") %></div>
  <%= button_to t("events.cancel"), event_participation_path(event), method: :delete,
                data: { turbo_confirm: "Na pewno anulujesz udział w tym evencie?" },
                class: "w-full py-3 rounded-lg border border-stone-300 text-stone-800 font-medium transition-transform active:scale-[0.97]" %>
<% elsif participation&.waitlist? %>
  <div class="rounded-lg bg-amber-50 text-amber-800 px-3 py-2 text-sm mb-3 animate-pop-in"><%= t("events.waitlist_badge") %></div>
  <%= button_to t("events.cancel"), event_participation_path(event), method: :delete,
                data: { turbo_confirm: "Na pewno zejdziesz z listy rezerwowej?" },
                class: "w-full py-3 rounded-lg border border-stone-300 text-stone-800 font-medium transition-transform active:scale-[0.97]" %>
<% elsif event.full? %>
  <%= button_to t("events.waitlist_accept"), event_participation_path(event), method: :post,
                class: "w-full py-3 rounded-lg bg-amber-500 text-white font-medium transition-transform active:scale-[0.97] hover:bg-amber-600" %>
<% else %>
  <%= button_to t("events.accept"), event_participation_path(event), method: :post,
                class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium transition-transform active:scale-[0.97] hover:bg-stone-800" %>
<% end %>
