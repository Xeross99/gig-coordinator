<%# locals: (event:, hosts:, url:, submit_label:, users_for_prereg: nil) -%>
<%= form_with model: event, url: url, local: true, class: "space-y-4" do |f| %>
  <% if event.errors.any? %>
    <div class="bg-red-50 text-red-800 rounded-lg p-3 text-sm">
      <ul class="list-disc list-inside">
        <% event.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :host_id, t("events.host_label"), class: "block text-sm text-stone-700 mb-1" %>
    <%= f.collection_select :host_id, hosts, :id, :display_name,
                            { include_blank: "— wybierz organizatora —" },
                            { required: true, class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" } %>
  </div>

  <div>
    <%= f.label :name, "Nazwa eventu", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.text_field :name, required: true, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= label_tag "event_event_date", "Data", class: "block text-sm text-stone-700 mb-1" %>
    <%= date_field_tag "event[event_date]", event.scheduled_at&.to_date, required: true,
                       id: "event_event_date",
                       class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <label class="block text-sm text-stone-700 mb-1"><%= t("events.starts_at") %></label>
    <% preset_start_hour   = event.scheduled_at&.hour || 18 %>
    <% preset_start_minute = event.scheduled_at&.min || 0 %>
    <div class="grid grid-cols-2 gap-3">
      <div class="flex items-center gap-2">
        <%= select_tag "event[start_hour]",
                       options_for_select((0..23).map { |h| [ format("%02d", h), h ] }, preset_start_hour),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">godz.</span>
      </div>
      <div class="flex items-center gap-2">
        <%= select_tag "event[start_minute]",
                       options_for_select((0..59).step(5).map { |m| [ format("%02d", m), m ] }, preset_start_minute),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">min.</span>
      </div>
    </div>
  </div>

  <div>
    <label class="block text-sm text-stone-700 mb-1"><%= t("events.duration") %></label>
    <% total_minutes = event.scheduled_at && event.ends_at ? ((event.ends_at - event.scheduled_at) / 60).to_i : 120 %>
    <% preset_hours   = total_minutes / 60 %>
    <% preset_minutes = total_minutes % 60 %>
    <div class="grid grid-cols-2 gap-3">
      <div class="flex items-center gap-2">
        <%= select_tag "event[duration_hours]",
                       options_for_select((0..24).to_a, preset_hours),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">godz.</span>
      </div>
      <div class="flex items-center gap-2">
        <%= select_tag "event[duration_minutes]",
                       options_for_select((0..55).step(5).to_a, preset_minutes),
                       required: true,
                       class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white tabular-nums" %>
        <span class="text-sm text-stone-500 shrink-0">min.</span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :pay_per_person, t("events.pay_per_person"), class: "block text-sm text-stone-700 mb-1" %>
      <%= f.select :pay_per_person,
                   (0..500).step(10).to_a,
                   {},
                   required: true, class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
    <div>
      <%= f.label :capacity, "Liczba miejsc", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.select :capacity,
                   (1..20).to_a,
                   {},
                   required: true, class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
  </div>

  <% if users_for_prereg.present? && users_for_prereg.any? %>
    <div>
      <label class="block text-sm text-stone-700 mb-1">Zapisz od razu</label>
      <p class="text-xs text-stone-500 mb-2">Zaznaczone osoby zostaną potwierdzone od razu. Rezerwacje Mistrza Pióra dotyczą pozostałych wolnych miejsc.</p>
      <div class="border border-stone-300 rounded-lg bg-white max-h-64 overflow-y-auto">
        <%= f.collection_check_boxes :pre_registered_user_ids, users_for_prereg, :id, :display_name do |b| %>
          <label class="flex items-center gap-3 px-3 py-2 cursor-pointer hover:bg-stone-50 border-b border-stone-100 last:border-b-0">
            <%= b.check_box class: "size-4 rounded border-stone-300 text-stone-900 focus:ring-stone-900" %>
            <%= render "events/roster_avatar", user: b.object %>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-stone-900 truncate"><%= b.object.display_name %></div>
              <div class="mt-0.5"><%= render "users/title_badge", user: b.object %></div>
            </div>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if Current.user.can_submit_events? %>
    <%= f.submit submit_label, class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium" %>
  <% else %>
    <div>
      <button type="button" disabled aria-disabled="true"
              class="w-full py-3 rounded-lg bg-stone-300 text-stone-500 font-medium cursor-not-allowed">
        <%= submit_label %>
      </button>
      <p class="mt-2 text-xs text-stone-500 text-center"><%= t("events.submit_disabled_hint") %></p>
    </div>
  <% end %>
<% end %>
