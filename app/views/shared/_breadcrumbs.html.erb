<%# Renders a breadcrumb trail. Locals:
     crumbs:    Array of [label, path] pairs (last one is current page; path may be nil).
     home_path: Path for the leading home icon (default root_path). %>
<% home_path ||= root_path %>
<% crumbs ||= [] %>
<nav aria-label="Breadcrumb" class="flex mb-4">
  <ol role="list" class="flex items-center space-x-4">
    <li>
      <div>
        <%= link_to home_path, class: "text-stone-400 hover:text-stone-600" do %>
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 shrink-0">
            <path d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
          <span class="sr-only">Start</span>
        <% end %>
      </div>
    </li>
    <% crumbs.each_with_index do |(label, path), i| %>
      <% is_last = i == crumbs.length - 1 %>
      <li>
        <div class="flex items-center">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 shrink-0 text-stone-300">
            <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
          </svg>
          <% if path.present? && !is_last %>
            <%= link_to label, path, class: "ml-4 text-sm font-medium text-stone-500 hover:text-stone-700" %>
          <% else %>
            <span aria-current="<%= "page" if is_last %>" class="ml-4 text-sm font-medium text-stone-700"><%= label %></span>
          <% end %>
        </div>
      </li>
    <% end %>
  </ol>
</nav>
