<%# Renders a breadcrumb trail. Locals:
     crumbs:    Array of [label, path] pairs (last one is current page; path may be nil).
     home_path: Path for the leading home icon (default root_path). %>
<% home_path ||= root_path %>
<% crumbs ||= [] %>
<nav aria-label="Breadcrumb" class="flex mb-4 min-w-0 w-full">
  <ol role="list" class="flex items-center gap-2 sm:gap-3 min-w-0 w-full">
    <li class="shrink-0">
      <%= link_to home_path, class: "flex text-stone-400 hover:text-stone-600" do %>
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 shrink-0">
          <path d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z" clip-rule="evenodd" fill-rule="evenodd" />
        </svg>
        <span class="sr-only">Start</span>
      <% end %>
    </li>
    <% crumbs.each_with_index do |(label, path), i| %>
      <% is_last = i == crumbs.length - 1 %>
      <%# min-w-0 on every crumb lets truncate() engage when the row would
          overflow — otherwise a long middle crumb (e.g. event name) pushes
          siblings off-viewport on narrow phones. The last crumb still gets
          flex-1 so it absorbs slack when things do fit. %>
      <li class="flex items-center gap-2 sm:gap-3 min-w-0 <%= is_last ? "flex-1" : "" %>">
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5 shrink-0 text-stone-300">
          <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
        </svg>
        <% if path.present? && !is_last %>
          <%= link_to label, path, class: "text-sm font-medium text-stone-500 hover:text-stone-700 truncate block min-w-0" %>
        <% else %>
          <span aria-current="<%= "page" if is_last %>" class="text-sm font-medium text-stone-700 truncate block min-w-0"><%= label %></span>
        <% end %>
      </li>
    <% end %>
  </ol>
</nav>
