<%# Google Maps embed with a pulsing skeleton underneath. While the iframe
    is still loading (opacity: 0) the stone-100 background + map-pin icon is
    visible; the onload handler bumps opacity to 1 and covers the skeleton. %>
<% location = local_assigns[:location] %>
<% height_class = local_assigns[:height_class] || "h-60" %>
<div class="relative bg-stone-100 overflow-hidden">
  <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 pointer-events-none">
    <div class="animate-pulse flex flex-col items-center gap-2">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-8 text-stone-300">
        <path fill-rule="evenodd" d="m9.69 18.933.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
      </svg>
      <span class="text-xs text-stone-400">Wczytywanie mapy…</span>
    </div>
  </div>
  <iframe src="<%= google_maps_embed_src(location) %>"
          width="100%"
          style="border:0"
          loading="lazy"
          allow="fullscreen"
          onload="this.style.opacity=1"
          referrerpolicy="no-referrer-when-downgrade"
          class="relative w-full <%= height_class %> opacity-0 transition-opacity duration-300"></iframe>
</div>
