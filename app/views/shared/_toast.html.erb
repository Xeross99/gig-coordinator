<%# Renders a flash toast (notice: green check / alert: red x). Consumed by layouts. %>
<% return unless flash[:notice] || flash[:alert] %>
<% kind = flash[:notice] ? :notice : :alert %>
<% message = flash[kind] %>

<div aria-live="assertive" class="pointer-events-none fixed inset-0 flex items-end px-4 py-6 sm:items-start sm:p-6 z-50">
  <div class="flex w-full flex-col items-center space-y-4 sm:items-end">
    <div data-controller="toast"
         class="pointer-events-auto w-full max-w-sm translate-y-0 transform rounded-lg bg-white opacity-100 shadow-lg outline-1 outline-black/5 transition duration-300 ease-out sm:translate-x-0 starting:translate-y-2 starting:opacity-0 starting:sm:translate-x-2 starting:sm:translate-y-0">
      <div class="p-4">
        <div class="flex items-start">
          <div class="shrink-0">
            <% if kind == :notice %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 text-emerald-500">
                <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            <% else %>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6 text-red-500">
                <path d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            <% end %>
          </div>
          <div class="ml-3 w-0 flex-1 pt-0.5">
            <p class="text-sm text-stone-700"><%= message %></p>
          </div>
          <div class="ml-4 flex shrink-0">
            <button type="button" data-action="click->toast#dismiss"
                    class="inline-flex rounded-md text-stone-400 hover:text-stone-600 focus:outline-2 focus:outline-offset-2 focus:outline-stone-900">
              <span class="sr-only">Zamknij</span>
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
                <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
