<!DOCTYPE html>
<html lang="pl">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} - Gig Coordinator" : "Gig Coordinator" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#d53838">
    <meta name="color-scheme" content="only light">
    <meta name="view-transition" content="same-origin" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-dvh flex flex-col overflow-hidden bg-stone-50 text-stone-900 antialiased">
    <%= render "shared/navbar" %>
    <%= render "shared/toast" %>

    <header class="shrink-0 bg-white border-b border-stone-200 px-3 py-2 flex items-center gap-3">
      <%= link_to event_path(@event),
                  class: "shrink-0 -ml-1 size-9 rounded-full hover:bg-stone-100 flex items-center justify-center text-stone-700",
                  title: "Wróć do eventu",
                  "aria-label": "Wróć do eventu" do %>
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
        </svg>
      <% end %>
      <div class="min-w-0 flex-1 text-sm font-semibold text-stone-900 truncate"><%= @event.name %></div>
    </header>

    <main class="flex-1 min-h-0 flex flex-col w-full max-w-lg mx-auto px-3 py-2">
      <%= yield %>
    </main>
  </body>
</html>
