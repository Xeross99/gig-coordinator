<!DOCTYPE html>
<html lang="pl">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} - Gig Coordinator" : "Gig Coordinator" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#d53838">
    <meta name="color-scheme" content="only light">
    <meta name="view-transition" content="same-origin" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-dvh flex flex-col overflow-hidden bg-stone-50 text-stone-900 antialiased">
    <%= render "shared/navbar" %>
    <%= render "shared/toast" %>

    <main class="flex-1 min-h-0 flex flex-col w-full max-w-lg mx-auto px-4 pt-3">
      <%= render "shared/breadcrumbs", crumbs: [
        [ @event.name, event_path(@event) ],
        [ "Czat", nil ]
      ] %>
      <%= yield %>
    </main>
  </body>
</html>
