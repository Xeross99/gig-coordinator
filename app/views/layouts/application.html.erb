<!DOCTYPE html>
<html lang="pl">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} - Gig Coordinator" : "Gig Coordinator" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gig Coordinator">
    <meta name="apple-mobile-web-app-title" content="Gig Coordinator">
    <meta name="theme-color" content="#d53838">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <%= tag.link rel: "manifest", href: pwa_manifest_path %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-dvh flex flex-col bg-stone-50 text-stone-900 antialiased">
    <% if current_user %>
      <div data-controller="push-subscription"
           data-push-subscription-vapid-public-key-value="<%= Rails.application.credentials.dig(:vapid, :public_key) %>"
           data-push-subscription-endpoint-url-value="<%= push_subscriptions_path %>"
           data-push-subscription-csrf-token-value="<%= form_authenticity_token %>"></div>
    <% end %>
    <% if signed_in? %>
      <% me = current_user || current_host %>
      <% profile_href = current_host ? edit_host_profile_path : edit_profile_path %>
      <nav class="sticky top-0 z-10 bg-white/90 backdrop-blur border-b border-stone-200 px-4 py-3">
        <div class="flex items-center justify-between gap-4 max-w-lg mx-auto">
          <%= link_to profile_href, class: "flex items-start space-x-4 min-w-0" do %>
            <div class="shrink-0">
              <div class="relative">
                <% if me.photo.attached? %>
                  <%= image_tag me.photo.variant(resize_to_fill: [64, 64]),
                                class: "size-12 rounded-full object-cover" %>
                <% else %>
                  <div class="size-12 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold">
                    <%= me.first_name[0] %><%= me.last_name[0] %>
                  </div>
                <% end %>
                <span aria-hidden="true" class="absolute inset-0 rounded-full shadow-inner"></span>
              </div>
            </div>
            <div class="pt-1 min-w-0">
              <h1 class="text-base font-semibold text-stone-900 truncate"><%= me.display_name %></h1>
              <div class="text-xs font-medium truncate">
                <% if current_host %>
                  <span class="text-stone-500"><%= t("host_panel.title") %></span>
                <% else %>
                  <%= render "users/title_badge", user: me %>
                <% end %>
              </div>
            </div>
          <% end %>

          <el-dropdown class="inline-block shrink-0">
            <button type="button"
                    class="inline-flex w-full justify-center items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-stone-900 shadow-xs inset-ring-1 inset-ring-stone-300 hover:bg-stone-50">
              Menu
              <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="-mr-1 size-5 text-stone-400">
                <path d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" fill-rule="evenodd" />
              </svg>
            </button>

            <el-menu anchor="bottom end" popover
                     class="w-60 origin-top-right divide-y divide-stone-100 rounded-md bg-white shadow-lg outline-1 outline-black/5
                            transition transition-discrete [--anchor-gap:--spacing(2)]
                            data-closed:scale-95 data-closed:transform data-closed:opacity-0
                            data-enter:duration-100 data-enter:ease-out
                            data-leave:duration-75 data-leave:ease-in">

              <div class="py-1">
                <%= link_to profile_href,
                            class: "group/item flex items-center px-4 py-2 text-sm text-stone-700 focus:bg-stone-100 focus:text-stone-900 focus:outline-hidden" do %>
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                       class="mr-3 size-5 text-stone-400 group-focus/item:text-stone-500">
                    <path d="M10 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM3.465 14.493a1.23 1.23 0 0 0 .41 1.412A9.957 9.957 0 0 0 10 18c2.31 0 4.438-.784 6.131-2.1.43-.333.604-.903.408-1.41a7.002 7.002 0 0 0-13.074.003Z"/>
                  </svg>
                  Mój profil
                <% end %>
              </div>

              <% unless current_host %>
                <div class="py-1">
                  <%= link_to users_path,
                              class: "group/item flex items-center px-4 py-2 text-sm text-stone-700 focus:bg-stone-100 focus:text-stone-900 focus:outline-hidden" do %>
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                         class="mr-3 size-5 text-stone-400 group-focus/item:text-stone-500">
                      <path d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM6 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM1.49 15.326a.78.78 0 0 1-.358-.442 3 3 0 0 1 4.308-3.516 6.484 6.484 0 0 0-1.905 3.959c-.023.222-.014.442.025.654a4.97 4.97 0 0 1-2.07-.655ZM16.44 15.98a4.97 4.97 0 0 0 2.07-.654.78.78 0 0 0 .357-.442 3 3 0 0 0-4.308-3.517 6.484 6.484 0 0 1 1.907 3.96 2.32 2.32 0 0 1-.026.654ZM18 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM5.304 16.19a.844.844 0 0 1-.277-.71 5 5 0 0 1 9.947 0 .843.843 0 0 1-.277.71A6.975 6.975 0 0 1 10 18a6.974 6.974 0 0 1-4.696-1.81Z"/>
                    </svg>
                    Wszyscy pracownicy
                  <% end %>
                  <%= link_to hosts_path,
                              class: "group/item flex items-center px-4 py-2 text-sm text-stone-700 focus:bg-stone-100 focus:text-stone-900 focus:outline-hidden" do %>
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                         class="mr-3 size-5 text-stone-400 group-focus/item:text-stone-500">
                      <path d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z" clip-rule="evenodd" fill-rule="evenodd"/>
                    </svg>
                    Wszyscy organizatorzy
                  <% end %>
                </div>
              <% end %>

              <% unless current_host %>
                <div class="py-1">
                  <%= link_to info_path,
                              class: "group/item flex items-center px-4 py-2 text-sm text-stone-700 focus:bg-stone-100 focus:text-stone-900 focus:outline-hidden" do %>
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                         class="mr-3 size-5 text-stone-400 group-focus/item:text-stone-500">
                      <path d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" fill-rule="evenodd"/>
                    </svg>
                    Jak to działa
                  <% end %>
                </div>
              <% end %>

              <div class="py-1">
                <%= button_to session_path, method: :delete,
                              form: { class: "block" },
                              class: "group/item flex w-full items-center px-4 py-2 text-left text-sm text-stone-700 focus:bg-stone-100 focus:text-stone-900 focus:outline-hidden" do %>
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                       class="mr-3 size-5 text-stone-400 group-focus/item:text-stone-500">
                    <path d="M3 4.25A2.25 2.25 0 0 1 5.25 2h5.5A2.25 2.25 0 0 1 13 4.25v2a.75.75 0 0 1-1.5 0v-2a.75.75 0 0 0-.75-.75h-5.5a.75.75 0 0 0-.75.75v11.5c0 .414.336.75.75.75h5.5a.75.75 0 0 0 .75-.75v-2a.75.75 0 0 1 1.5 0v2A2.25 2.25 0 0 1 10.75 18h-5.5A2.25 2.25 0 0 1 3 15.75V4.25Z"/>
                    <path d="M19 10a.75.75 0 0 0-.22-.53l-3.25-3.25a.75.75 0 0 0-1.06 1.06L16.94 9.25H8a.75.75 0 0 0 0 1.5h8.94l-2.47 2.47a.75.75 0 1 0 1.06 1.06l3.25-3.25A.75.75 0 0 0 19 10Z"/>
                  </svg>
                  <%= t("auth.logout") %>
                <% end %>
              </div>
            </el-menu>
          </el-dropdown>
        </div>
      </nav>
    <% end %>

    <%= render "shared/toast" %>
    <%= render "shared/turbo_confirm" %>

    <main class="flex-1 w-full max-w-lg mx-auto px-4 py-4">
      <%= yield %>
    </main>

    <footer class="bg-white border-t border-stone-200 mt-8">
      <div class="mx-auto max-w-lg px-6 py-8 md:flex md:items-center md:justify-between">
        <div class="flex justify-center gap-x-6 md:order-2">
          <a href="https://www.instagram.com/gig-coordinator_catchers/" target="_blank" rel="noopener" class="text-stone-500 hover:text-stone-800">
            <span class="sr-only">Instagram</span>
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-6">
              <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" fill-rule="evenodd" />
            </svg>
          </a>
        </div>
        <div class="mt-6 text-center md:order-1 md:mt-0 md:text-left">
          <p class="text-sm text-stone-700">&copy; <%= Time.current.year %> Gig Coordinator</p>
          <p class="mt-1 text-xs text-stone-500">
            Wykonał <a href="https://example.pl" target="_blank" rel="noopener" class="underline hover:text-stone-700">Michał Kowalska</a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
