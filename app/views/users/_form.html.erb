<%= form_with model: user, local: true, class: "space-y-4 bg-white rounded-xl shadow-sm p-5" do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 text-red-800 rounded-lg p-3 text-sm">
      <ul class="list-disc list-inside">
        <% user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <% if user.photo.attached? %>
    <div class="flex items-center gap-3">
      <%= image_tag user.photo.variant(:small), class: "size-16 rounded-full object-cover", alt: "#{user.display_name} image" %>
      <div class="text-sm text-stone-500">Obecne zdjęcie</div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, "Imię", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.text_field :first_name, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
    <div>
      <%= f.label :last_name, "Nazwisko", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.text_field :last_name, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.email_field :email, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= f.label :phone, "Telefon (opcjonalnie)", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.telephone_field :phone, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= f.label :title, "Ranga", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.select :title,
                 User.titles.keys.map { |k| [I18n.t("user.titles.#{k}"), k] },
                 {},
                 class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <% hosts_for_form = Host.order(:last_name, :first_name) %>

  <div>
    <div class="block text-sm text-stone-700 mb-1"><%= t("user.manages") %> (obiekty)</div>
    <% if hosts_for_form.any? %>
      <div class="space-y-1 rounded-lg border border-stone-300 bg-white p-3 max-h-56 overflow-y-auto">
        <%= f.collection_check_boxes :managed_host_ids, hosts_for_form, :id, :display_name do |b| %>
          <label class="flex items-center gap-2 text-sm py-1">
            <%= b.check_box class: "size-4 rounded border-stone-300" %>
            <span class="text-stone-900"><%= b.object.display_name %></span>
            <span class="text-stone-400 text-xs">— <%= b.object.location %></span>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-stone-500 mt-1">Działa tylko dla Obiektowego Komendanta — u innych rang lista jest tylko zapisywana i wchodzi w życie po awansie.</p>
    <% else %>
      <p class="text-sm text-stone-400">Brak organizatorów w systemie.</p>
    <% end %>
  </div>

  <div>
    <div class="block text-sm text-stone-700 mb-1 flex items-center gap-1.5">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true" class="size-3.5 text-red-500">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
      </svg>
      Blokady u organizatorów
    </div>
    <% if user.master? %>
      <div class="rounded-lg border border-stone-200 bg-stone-50 p-3 text-sm text-stone-500">
        Mistrz nie podlega blokadom. Zmień najpierw rangę, jeśli chcesz założyć blokadę.
      </div>
      <%# Sentinel — bez tego odznaczenie wszystkich kratek nie wysłałoby parametru. %>
      <%= hidden_field_tag "user[blocked_host_ids][]", "" %>
    <% elsif hosts_for_form.any? %>
      <div class="space-y-1 rounded-lg border border-stone-300 bg-white p-3 max-h-56 overflow-y-auto">
        <%= f.collection_check_boxes :blocked_host_ids, hosts_for_form, :id, :display_name do |b| %>
          <label class="flex items-center gap-2 text-sm py-1">
            <%= b.check_box class: "size-4 rounded border-stone-300" %>
            <span class="text-stone-900"><%= b.object.display_name %></span>
            <span class="text-stone-400 text-xs">— <%= b.object.location %></span>
          </label>
        <% end %>
      </div>
      <p class="text-xs text-stone-500 mt-1">Zaznaczony = user nie może się zapisać na eventy tego organizatora.</p>
    <% else %>
      <p class="text-sm text-stone-400">Brak organizatorów w systemie.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :photo, "Zdjęcie", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
  </div>

  <p class="text-xs text-stone-500">
    <%= t("admin.users.admin_hint",
          value: user.admin? ? t("admin.users.admin_yes") : t("admin.users.admin_no")) %>
  </p>

  <%= f.submit "Zapisz", class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium" %>
<% end %>
