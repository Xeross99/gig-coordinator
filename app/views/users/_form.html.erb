<%= form_with model: user, local: true, class: "space-y-4 bg-white rounded-xl shadow-sm p-5" do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 text-red-800 rounded-lg p-3 text-sm">
      <ul class="list-disc list-inside">
        <% user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <% if user.photo.attached? %>
    <div class="flex items-center gap-3">
      <%= image_tag user.photo.variant(:small), class: "size-16 rounded-full object-cover", alt: "#{user.display_name} image" %>
      <div class="text-sm text-stone-500">Obecne zdjęcie</div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, "Imię", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.text_field :first_name, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
    <div>
      <%= f.label :last_name, "Nazwisko", class: "block text-sm text-stone-700 mb-1" %>
      <%= f.text_field :last_name, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
    </div>
  </div>

  <div>
    <%= f.label :email, "E-mail", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.email_field :email, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= f.label :phone, "Telefon (opcjonalnie)", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.telephone_field :phone, class: "w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= f.label :title, "Ranga", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.select :title,
                 User.titles.keys.map { |k| [I18n.t("user.titles.#{k}"), k] },
                 {},
                 class: "form-select w-full px-3 py-3 rounded-lg border border-stone-300 bg-white" %>
  </div>

  <div>
    <%= f.label :photo, "Zdjęcie", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
  </div>

  <p class="text-xs text-stone-500">
    <%= t("admin.users.admin_hint",
          value: user.admin? ? t("admin.users.admin_yes") : t("admin.users.admin_no")) %>
  </p>

  <%= f.submit "Zapisz", class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium" %>
<% end %>
