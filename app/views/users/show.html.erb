<% content_for(:title) { @user.display_name } %>
<%= render "shared/breadcrumbs", crumbs: [
  ["Wszyscy pracownicy", users_path],
  [@user.display_name, nil]
] %>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <%# Hero: original-resolution photo (no :small variant), falls back to initials. %>
  <% if @user.photo.attached? %>
    <div class="bg-stone-100">
      <%= image_tag rails_blob_path(@user.photo, only_path: true),
                    alt: @user.display_name,
                    class: "w-full aspect-square object-cover" %>
    </div>
  <% else %>
    <div class="w-full aspect-square bg-stone-200 flex items-center justify-center">
      <span class="text-6xl font-semibold text-stone-500">
        <%= @user.first_name[0] %><%= @user.last_name[0] %>
      </span>
    </div>
  <% end %>

  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h1 class="text-2xl font-semibold text-stone-900 truncate"><%= @user.display_name %></h1>
        <div class="mt-1 flex items-center gap-2 text-xs">
          <% if @user.online? %>
            <span class="inline-flex items-center gap-1 text-emerald-600 font-medium">
              <span class="size-2 rounded-full bg-emerald-500"></span> Online teraz
            </span>
          <% elsif @user.last_seen_at.present? %>
            <span class="inline-flex items-center gap-1 text-stone-500">
              <span class="size-2 rounded-full bg-stone-300"></span>
              Ostatnio <%= time_ago_in_words(@user.last_seen_at) %> temu
            </span>
          <% else %>
            <span class="text-stone-400">Nigdy się nie logował</span>
          <% end %>
        </div>
      </div>
      <div class="shrink-0 flex flex-col items-end gap-2">
        <%= render "users/title_badge", user: @user %>
        <% if admin_signed_in? %>
          <%= link_to t("admin.users.edit_link"), edit_user_path(@user),
                      class: "text-sm font-medium text-stone-900 underline" %>
        <% end %>
      </div>
    </div>

    <dl class="grid grid-cols-2 gap-3 mt-5 text-sm">
      <div class="col-span-2">
        <dt class="text-stone-500 text-xs uppercase tracking-wide">E-mail</dt>
        <dd class="font-medium break-all <%= "text-stone-400" if @user.email.blank? %>">
          <% if @user.email.present? %>
            <%= link_to @user.email, "mailto:#{@user.email}", class: "text-stone-900 hover:underline" %>
          <% else %>
            Nie podano
          <% end %>
        </dd>
      </div>
      <div class="col-span-2">
        <dt class="text-stone-500 text-xs uppercase tracking-wide">Telefon</dt>
        <dd class="font-medium <%= "text-stone-400" if @user.phone.blank? %>">
          <% if @user.phone.present? %>
            <%= link_to @user.phone, "tel:#{@user.phone}", class: "text-stone-900 hover:underline" %>
          <% else %>
            Nie podano
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-stone-500 text-xs uppercase tracking-wide">Ranga</dt>
        <dd class="font-medium"><%= @user.display_title %></dd>
      </div>
      <div>
        <dt class="text-stone-500 text-xs uppercase tracking-wide flex items-center gap-1">
          <span aria-hidden="true">🐔</span> Zaliczone łapania
        </dt>
        <dd class="font-semibold text-lg tabular-nums"><%= @catches_count %></dd>
      </div>
      <div>
        <dt class="text-stone-500 text-xs uppercase tracking-wide">Dołączył</dt>
        <dd class="font-medium"><%= l(@user.created_at.to_date, format: :long) %></dd>
      </div>
    </dl>
  </div>

  <% if @managed_hosts.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3"><%= @user.master? ? t("user.manages_all") : t("user.manages") %></h2>
      <ul class="space-y-2">
        <% @managed_hosts.each do |host| %>
          <li>
            <%= link_to host_path(host), class: "flex items-center gap-3 text-sm" do %>
              <% if host.photo.attached? %>
                <%= image_tag rails_representation_path(host.photo.variant(:small), only_path: true),
                              class: "size-10 rounded-full object-cover shrink-0" %>
              <% else %>
                <div class="size-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold text-xs shrink-0">
                  <%= host.first_name[0] %><%= host.last_name[0] %>
                </div>
              <% end %>
              <div class="min-w-0">
                <div class="font-medium text-stone-900 truncate"><%= host.display_name %></div>
                <div class="text-stone-500 text-xs truncate"><%= host.location %></div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @blocked_hosts.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true" class="size-3.5 text-red-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
        </svg>
        <%= t("user.blocked_at") %>
      </h2>
      <ul class="space-y-2">
        <% @blocked_hosts.each do |host| %>
          <li>
            <%= link_to host_path(host), class: "flex items-center gap-3 text-sm" do %>
              <% if host.photo.attached? %>
                <%= image_tag rails_representation_path(host.photo.variant(:small), only_path: true),
                              class: "size-10 rounded-full object-cover shrink-0" %>
              <% else %>
                <div class="size-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold text-xs shrink-0">
                  <%= host.first_name[0] %><%= host.last_name[0] %>
                </div>
              <% end %>
              <div class="min-w-0">
                <div class="font-medium text-stone-900 truncate"><%= host.display_name %></div>
                <div class="text-stone-500 text-xs truncate"><%= host.location %></div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @upcoming.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3">Nadchodzące łapania</h2>
      <ul class="space-y-2">
        <% @upcoming.each do |p| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <%= link_to p.event.name, event_path(p.event),
                        class: "font-medium text-stone-900 hover:underline truncate min-w-0 flex-1" %>
            <span class="shrink-0 text-xs text-stone-500 tabular-nums">
              <%= l(p.event.scheduled_at, format: :short) %>
            </span>
            <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium
                         <%= { 'confirmed' => 'bg-emerald-100 text-emerald-700',
                               'waitlist'  => 'bg-amber-100 text-amber-700',
                               'reserved'  => 'bg-indigo-100 text-indigo-700' }[p.status] %>">
              <%= { 'confirmed' => 'zapisany',
                    'waitlist'  => 'rezerwa',
                    'reserved'  => 'oczekuje' }[p.status] %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @past_confirmed.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3">Historia zakończonych łapań</h2>
      <ul class="space-y-2">
        <% @past_confirmed.each do |p| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <%= link_to p.event.name, event_path(p.event),
                        class: "font-medium text-stone-900 hover:underline truncate min-w-0 flex-1" %>
            <span class="shrink-0 text-xs text-stone-500 tabular-nums">
              <%= l(p.event.scheduled_at.to_date) %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
