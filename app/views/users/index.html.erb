<% content_for(:title) { "Wszyscy pracownicy" } %>
<%= render "shared/breadcrumbs", crumbs: [["Wszyscy pracownicy", nil]] %>

<div class="flex items-center justify-between mb-4">
  <h1 class="text-2xl font-semibold">Wszyscy pracownicy</h1>
  <% if admin_signed_in? %>
    <%= link_to t("admin.users.add_button"), new_user_path, class: "shrink-0 px-3 py-2 rounded-lg bg-stone-900 text-white text-sm font-medium" %>
  <% end %>
</div>

<div class="mb-4">
  <%= render "shared/sort_toggle",
             options: [["rank", "Ranga"], ["name_asc", "Od A do Z"], ["name_desc", "Od Z do A"]],
             current: @sort,
             path_helper: :users_path,
             full_width: true %>
</div>

<% if @users.any? %>
  <div class="sort-target">
  <div class="flex items-center justify-between px-4 pb-2 text-[11px] font-semibold uppercase tracking-wider text-stone-500">
    <span>Pracownik</span>
    <span class="flex items-center gap-1">
      <span aria-hidden="true"></span>
      <span>Ukończone wydarzenia</span>
    </span>
  </div>
  <ul class="space-y-3">
    <% @users.each do |user| %>
      <% catches = @catch_counts[user.id] || 0 %>
      <li class="bg-white rounded-xl shadow-sm">
        <%= link_to user_path(user), class: "p-4 flex items-center gap-4 rounded-xl hover:bg-stone-50 active:bg-stone-100 transition-colors" do %>
        <div class="relative shrink-0">
          <% if user.photo.attached? %>
            <%= image_tag user.photo.variant(:small),
                          alt: user.display_name,
                          class: "size-14 rounded-full object-cover" %>
          <% else %>
            <div class="size-14 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold">
              <%= user.first_name[0] %><%= user.last_name[0] %>
            </div>
          <% end %>
          <span aria-hidden="true"
                title="<%= user.online? ? "Online" : "Offline" %>"
                class="absolute bottom-0 right-0 block size-3 rounded-full ring-2 ring-white <%= user.online? ? "bg-emerald-500" : "bg-stone-300" %>"></span>
        </div>
        <div class="min-w-0 flex-1">
          <div class="font-medium text-stone-900 truncate"><%= user.display_name %></div>
          <div class="mt-1"><%= render "users/title_badge", user: user %></div>
          <div class="mt-1 text-xs text-stone-500">
            <% if user.online? %>
              <span class="text-emerald-600 font-medium">● Online</span>
            <% elsif user.last_seen_at.present? %>
              Ostatnio <%= time_ago_in_words(user.last_seen_at) %> temu
            <% else %>
              Nigdy się nie logował
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-1.5 shrink-0" title="Ukończone wydarzenia">
          <span class="text-lg leading-none" aria-hidden="true"></span>
          <span class="text-sm font-semibold text-stone-900 tabular-nums"><%= catches %></span>
        </div>
        <% end %>
      </li>
    <% end %>
  </ul>
  </div>
<% else %>
  <div class="text-stone-500 py-8 text-center">Brak pracowników.</div>
<% end %>
