<% content_for(:title) { @host.display_name } %>
<%= render "shared/breadcrumbs", crumbs: [
  ["Wszyscy organizatorzy", hosts_path],
  [@host.display_name, nil]
] %>

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <% if @host.photo.attached? %>
    <div class="bg-stone-100">
      <%= image_tag rails_blob_path(@host.photo, only_path: true),
                    alt: @host.display_name,
                    class: "w-full aspect-square object-cover" %>
    </div>
  <% else %>
    <div class="w-full aspect-square bg-stone-200 flex items-center justify-center">
      <span class="text-6xl font-semibold text-stone-500">
        <%= @host.first_name[0] %><%= @host.last_name[0] %>
      </span>
    </div>
  <% end %>

  <div class="p-5">
    <div class="flex items-start justify-between gap-3">
      <h1 class="text-2xl font-semibold text-stone-900 truncate"><%= @host.display_name %></h1>
      <% if admin_signed_in? %>
        <%= link_to t("admin.hosts.edit_link"), edit_host_path(@host),
                    class: "shrink-0 text-sm font-medium text-stone-900 underline" %>
      <% end %>
    </div>

    <dl class="grid grid-cols-1 gap-3 mt-5 text-sm">
      <div>
        <dt class="text-stone-500 text-xs uppercase tracking-wide">E-mail</dt>
        <dd class="font-medium break-all <%= "text-stone-400" if @host.email.blank? %>">
          <%= @host.email.presence || "brak" %>
        </dd>
      </div>
      <% if @host.phone.present? %>
        <div>
          <dt class="text-stone-500 text-xs uppercase tracking-wide">Telefon</dt>
          <dd class="font-medium"><%= link_to @host.phone, "tel:#{@host.phone}", class: "text-stone-900 hover:underline" %></dd>
        </div>
      <% end %>
      <div>
        <dt class="text-stone-500 text-xs uppercase tracking-wide">Lokalizacja</dt>
        <dd class="font-medium"><%= @host.location %></dd>
      </div>
    </dl>
  </div>

  <% if @host.location.present? %>
    <div class="border-t border-stone-200">
      <%= render "shared/map_embed", location: @host.location, height_class: "h-56" %>
    </div>
    <%= link_to t("events.open_in_maps"), google_maps_open_url(@host.location),
                target: "_blank", rel: "noopener",
                class: "block text-center py-2 text-xs text-stone-600 hover:text-stone-900 border-t border-stone-100" %>
  <% end %>

  <% if @host.managers.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3"><%= t("hosts.commanders") %></h2>
      <ul class="space-y-2">
        <% @host.managers.each do |user| %>
          <li>
            <%= link_to user_path(user), class: "flex items-center gap-3 text-sm" do %>
              <% if user.photo.attached? %>
                <%= image_tag rails_representation_path(user.photo.variant(:small), only_path: true),
                              class: "size-10 rounded-full object-cover shrink-0" %>
              <% else %>
                <div class="size-10 rounded-full bg-stone-200 flex items-center justify-center text-stone-600 font-semibold text-xs shrink-0">
                  <%= user.first_name[0] %><%= user.last_name[0] %>
                </div>
              <% end %>
              <div class="min-w-0 flex-1">
                <div class="font-medium text-stone-900 truncate"><%= user.display_name %></div>
              </div>
              <span class="shrink-0"><%= render "users/title_badge", user: user %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @upcoming_events.any? %>
    <div class="border-t border-stone-200 p-5">
      <h2 class="text-stone-500 text-xs uppercase tracking-wide mb-3">Nadchodzące łapania</h2>
      <ul class="space-y-2">
        <% @upcoming_events.each do |event| %>
          <li class="flex items-center justify-between gap-3 text-sm">
            <%= link_to event.name, event_path(event),
                        class: "font-medium text-stone-900 hover:underline truncate min-w-0 flex-1" %>
            <span class="shrink-0 text-xs text-stone-500 tabular-nums">
              <%= l(event.scheduled_at, format: :short) %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
