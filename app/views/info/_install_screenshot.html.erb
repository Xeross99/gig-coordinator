<%# Locals: name (filename under public/install, without extension), caption.
    Renders the real image if present, otherwise a dashed placeholder box
    telling the editor exactly which file to drop in. %>
<% file = Rails.root.join("public", "install", "#{name}.png") %>
<figure class="my-4">
  <% if File.exist?(file) %>
    <%= image_tag "/install/#{name}.png", alt: caption,
                  class: "mx-auto max-w-xs rounded-xl shadow-sm ring-1 ring-stone-200" %>
  <% else %>
    <div class="mx-auto max-w-xs aspect-[9/16] border-2 border-dashed border-stone-300 rounded-xl bg-stone-50 flex items-center justify-center p-6">
      <div class="text-center">
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="mx-auto size-8 text-stone-300 mb-2">
          <path d="M1 5.25A2.25 2.25 0 0 1 3.25 3h13.5A2.25 2.25 0 0 1 19 5.25v9.5A2.25 2.25 0 0 1 16.75 17H3.25A2.25 2.25 0 0 1 1 14.75v-9.5Zm1.5 5.81v3.69c0 .414.336.75.75.75h13.5a.75.75 0 0 0 .75-.75v-2.69l-2.22-2.219a.75.75 0 0 0-1.06 0l-1.91 1.909.47.47a.75.75 0 1 1-1.06 1.06L6.53 8.091a.75.75 0 0 0-1.06 0L2.5 11.06ZM7 5.75a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5Z" clip-rule="evenodd" fill-rule="evenodd"/>
        </svg>
        <p class="text-xs text-stone-400">
          Dodaj zrzut ekranu:<br>
          <code class="text-stone-500 font-mono text-[11px]">public/install/<%= name %>.png</code>
        </p>
      </div>
    </div>
  <% end %>
  <figcaption class="text-xs text-stone-500 text-center mt-2"><%= caption %></figcaption>
</figure>
