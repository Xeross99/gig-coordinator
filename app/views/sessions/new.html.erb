<div class="min-h-screen flex items-center justify-center px-6 bg-stone-50">
  <div class="w-full max-w-sm bg-white rounded-2xl shadow-sm p-8">
    <h1 class="text-2xl font-semibold text-stone-900 mb-1"><%= t("auth.login_title") %></h1>
    <p class="text-sm text-stone-500 mb-6">GigCoordinator · panel pracy</p>

    <% if flash[:alert] %>
      <div class="mb-4 rounded-lg bg-red-50 text-red-800 px-3 py-2 text-sm"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="mb-4 rounded-lg bg-emerald-50 text-emerald-800 px-3 py-2 text-sm"><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: magic_links_path, scope: :magic_link, method: :post, local: true do |f| %>
      <label class="block text-sm text-stone-700 mb-2" for="magic_link_email"><%= t("auth.email_label") %></label>
      <%= f.email_field :email, id: "magic_link_email", required: true, autocomplete: "email",
            class: "w-full px-3 py-3 rounded-lg border border-stone-300 focus:outline-none focus:ring-2 focus:ring-stone-900" %>
      <%= f.submit t("auth.send_link"),
            class: "mt-4 w-full py-3 rounded-lg bg-stone-900 text-white font-medium hover:bg-stone-800" %>
    <% end %>
  </div>
</div>
