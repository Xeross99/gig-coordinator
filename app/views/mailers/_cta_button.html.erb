<%# locals: (label:, url:) -%>
<table width="100%" border="0" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding:12px 20px;text-align:center">
      <table cellpadding="0" cellspacing="0" border="0" style="margin:0 auto">
        <tr>
          <td bgcolor="#0c0a09" style="background-color:#0c0a09;border-radius:8px">
            <a href="<%= url %>" target="_blank"
               style="display:inline-block;padding:14px 36px;font-size:15px;font-family:Arial,Helvetica,sans-serif;color:#ffffff;text-decoration:none;font-weight:bold;letter-spacing:0.3px">
              <%= label %>
            </a>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
