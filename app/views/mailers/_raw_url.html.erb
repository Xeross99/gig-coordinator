<%# locals: (url:) -%>
<table width="100%" border="0" cellpadding="0" cellspacing="0">
  <tr>
    <td style="padding:16px 20px 0;text-align:center">
      <span style="font-size:12px;font-family:Arial,Helvetica,sans-serif;color:#a8a29e;line-height:1.5">
        Jeśli przycisk nie działa, skopiuj ten adres do przeglądarki:
        <br>
        <a href="<%= url %>" style="color:#78716c;word-break:break-all"><%= url %></a>
      </span>
    </td>
  </tr>
</table>
