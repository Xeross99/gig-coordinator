<% content_for(:title) { "Mój profil" } %>
<%= render "shared/breadcrumbs", crumbs: [["Mój profil", nil]] %>

<h1 class="text-2xl font-semibold mb-4">Mój profil</h1>

<div class="bg-white rounded-xl shadow-sm p-5 mb-4">
  <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
    <div>
      <dt class="text-stone-500">Imię</dt>
      <dd class="font-medium"><%= @user.first_name %></dd>
    </div>
    <div>
      <dt class="text-stone-500">Nazwisko</dt>
      <dd class="font-medium"><%= @user.last_name %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="text-stone-500">E-mail</dt>
      <dd class="font-medium"><%= @user.email %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="text-stone-500">Ranga</dt>
      <dd><%= render "users/title_badge", user: @user %></dd>
    </div>
  </dl>
  <p class="mt-3 text-xs text-stone-500 text-center">Zmiana imienia, nazwiska lub adresu e-mail wymaga kontaktu z administratorem.</p>
</div>

<%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-4 bg-white rounded-xl shadow-sm p-5" do |f| %>
  <% if @user.errors.any? %>
    <div class="bg-red-50 text-red-800 rounded-lg p-3 text-sm">
      <ul class="list-disc list-inside">
        <% @user.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <% if @user.photo.attached? %>
    <div class="flex items-center gap-3">
      <%= image_tag @user.photo.variant(resize_to_fill: [64, 64]), alt: "#{@user.display_name} photo", class: "w-16 h-16 rounded-full object-cover" %>
      <div class="text-sm text-stone-500">Obecne zdjęcie</div>
    </div>
  <% end %>

  <div>
    <%= f.label :photo, "Zdjęcie profilowe", class: "block text-sm text-stone-700 mb-1" %>
    <%= f.file_field :photo, accept: "image/*", class: "block" %>
  </div>

  <%= f.submit "Zapisz zdjęcie", class: "w-full py-3 rounded-lg bg-stone-900 text-white font-medium" %>
<% end %>
